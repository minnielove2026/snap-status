{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "snap-status",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "snaps.popey.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
